# AdsPower API Configuration
# Copy this file to .env and fill in your values
# cp .env.example .env

# Your AdsPower API Key (get it from: Automation → API → Generate)
ADSPOWER_API_KEY=your_api_key_here

# API base URL (usually no need to change this)
ADSPOWER_API_BASE=http://local.adspower.net:50325
